# ─── MineAssist 994F – Backend ────────────────────────────────────────────────
# Copier ce fichier en `.env` à la racine de `backend/` et compléter les valeurs.
# Ne JAMAIS committer le fichier `.env` réel (il est ignoré par .gitignore).

# ── Identité de l'application
APP_NAME=MineAssist 994F
ENV=dev                              # dev | production

# ── Authentification JWT
# IMPORTANT : générer une clef forte en production avec :
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── CORS (origines autorisées du frontend, séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── RAG / LLM (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
TOP_K=5
MAX_CHARS_CONTEXT=6000

# ── Notifications email (optionnel)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
